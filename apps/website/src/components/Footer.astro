---
import { ThemeSwitcher } from "@openmarch/ui/astro";
import NewsletterForm from "./ui/NewsletterForm";
import { LogoOpenMarchText, LogoOpenMarchMarcher } from "./Logos";
import { Button } from "@openmarch/ui";

interface Props {
    hideDownloadCta?: boolean;
}

const { hideDownloadCta } = Astro.props;
---

<footer class="z-50 flex w-full flex-col gap-8">
    {
        !hideDownloadCta && (
            <div class="rounded-6 download-cta-gradient flex flex-col items-center gap-12 px-16 py-32">
                <LogoOpenMarchMarcher
                    width="24"
                    height="64"
                    className="text-accent"
                />
                <h2 class="text-h2 max-[768px]:text-h3 text-center">
                    Download the modern drill writing app
                </h2>
                <a
                    href="/download"
                    class="text-body hover:text-accent w-fit duration-150 ease-out"
                >
                    <Button variant="primary">Download</Button>
                </a>
            </div>
        )
    }
    <footer
        class="rounded-6 bg-fg-1 border-stroke divide-stroke grid grid-cols-4 gap-0 divide-x border px-16 py-32 max-[1024px]:grid-cols-2 max-[1024px]:gap-32 max-[1024px]:divide-x-0 max-[768px]:grid-cols-1"
    >
        <div
            class="flex flex-col justify-between px-16 max-[1024px]:col-span-2 max-[768px]:col-span-1"
        >
            <div class="flex flex-col gap-24">
                <div class="flex w-full justify-between gap-16 pr-4">
                    <a href="/">
                        <LogoOpenMarchText height="64" width="115" />
                    </a>
                    <ThemeSwitcher />
                </div>
                <a
                    class="text-body hover:text-accent leading-[150%] duration-150 ease-out"
                    href="mailto:contact@openmarch.com"
                >
                    contact@openmarch.com
                </a>
            </div><div class="flex flex-col gap-8">
                <p class="text-body leading-[150%]">
                    Stay up to date with our newsletter!
                </p>
                <NewsletterForm client:visible />
            </div>
        </div>
        <div class="flex flex-col gap-16 px-16 max-[768px]:pt-32">
            <h4 class="text-h4">Support & follow us</h4>
            <a
                href="https://store.openmarch.com"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Merch
            </a>
            <a
                href="https://www.patreon.com/openmarch"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Patreon
            </a>
            <a
                href="https://discord.gg/eTsQ98uZzq"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Discord
            </a>
            <a
                href="https://www.instagram.com/openmarchapp/"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Instagram
            </a>
            <a
                href="https://facebook-group.openmarch.com"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Facebook Group
            </a>
            <a
                href="https://www.youtube.com/@OpenMarchApp"
                target="_blank"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                YouTube
            </a>
        </div>
        <div class="flex flex-col gap-16 px-16 max-[768px]:pt-32">
            <h4 class="text-h4">App</h4>
            <a
                href="/download"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Download
            </a>
            <a
                href="/#features"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Features
            </a>
            <a
                href="/download#releases"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Releases
            </a>
            <a
                href="/guides"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Guides
            </a>
            <a
                href="/guides/submitting-feedback/"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Feedback
            </a>
            <a
                href="https://github.com/OpenMarch"
                target="_blank"
                class="text-body hover:text-accent duration-150 ease-out"
            >
                GitHub
            </a>
        </div>
        <div class="flex flex-col gap-16 px-16 max-[768px]:pt-32">
            <h4 class="text-h4">Organization</h4>
            <a
                href="/about"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                About
            </a>
            <a
                href="/blog"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Blog
            </a>
            <a
                href="/legal/terms"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Terms of Service
            </a>
            <a
                href="/legal/privacy"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Privacy Policy
            </a>
            <a
                href="/legal/refunds"
                class="text-body hover:text-accent w-fit duration-150 ease-out"
            >
                Refund Policy
            </a>
        </div>
    </footer>
</footer>
