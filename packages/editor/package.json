{
    "name": "@openmarch/editor",
    "version": "0.1.0",
    "type": "module",
    "license": "AGPL-3.0",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "publishConfig": {
        "@openmarch:registry": "https://npm.pkg.github.com"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./platform": {
            "types": "./dist/platform/index.d.ts",
            "import": "./dist/platform/index.js"
        }
    },
    "files": [
        "dist/**/*",
        "README.md",
        "LICENSE"
    ],
    "scripts": {
        "dev": "tsup --watch",
        "build": "tsup --format esm,cjs",
        "typecheck": "tsc --noEmit",
        "lint": "eslint . --fix",
        "test": "vitest run --silent",
        "test:watch": "vitest"
    },
    "peerDependencies": {
        "react": "^18.0.0 || ^19.0.0",
        "react-dom": "^18.0.0 || ^19.0.0"
    },
    "dependencies": {
        "@openmarch/core": "workspace:*",
        "@openmarch/ui": "workspace:*",
        "@tanstack/react-query": "^5.84.1",
        "drizzle-orm": "^0.43.1",
        "zustand": "^4.5.7",
        "fabric": "^5.5.2",
        "clsx": "^2.1.1",
        "tailwind-merge": "^2.6.0",
        "class-variance-authority": "^0.7.1"
    },
    "devDependencies": {
        "@openmarch/config": "workspace:*",
        "@types/react": "^19.1.8",
        "@types/react-dom": "^19.1.6",
        "@types/fabric": "^5.3.10",
        "tsup": "^8.5.0",
        "typescript": "~5.3.3",
        "vitest": "^4.0.0"
    }
}
