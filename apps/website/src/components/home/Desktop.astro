---
import { Badge, getButtonClassName } from "@openmarch/ui";
import { Image } from "astro:assets";

import shapesDark from "@/assets/desktop/shapesdark.png";
import shapesLight from "@/assets/desktop/shapeslight.png";
import tagsDark from "@/assets/desktop/tagsdark.png";
import tagsLight from "@/assets/desktop/tagslight.png";
import fieldDark from "@/assets/desktop/fielddark.png";
import fieldLight from "@/assets/desktop/fieldlight.png";
import viewVertDark from "@/assets/otm/viewvertdark.png";
import viewVertLight from "@/assets/otm/viewvertlight.png";
import drillchart from "@/assets/desktop/drillchart.png";
---

<section class="flex w-full min-w-0 flex-col gap-8" id="desktop">
    <Badge>Desktop</Badge>
    <h1
        class="text-text text-[3.5rem] leading-[115%] max-[768px]:text-h1 max-[520px]:text-h2"
    >
        The free, modern drill writing app
    </h1>
    <section
        class="grid grid-cols-2 grid-rows-2 gap-16 max-[850px]:grid-cols-1 max-[850px]:grid-rows-none"
    >
        <div
            class="bg-fg-1 border border-stroke rounded-6 p-24 flex flex-col gap-16 h-435 overflow-clip max-[850px]:h-auto max-[520px]:p-16"
        >
            <h3 class="text-h3 leading-none max-[520px]:text-h4">
                Intuitive design
            </h3>
            <p class="text-body leading-relaxed text-text-subtitle">
                Add in your field/floor, create music measures, and fluidly
                write drill in one beautiful workspace.
            </p>

            <Image
                src={shapesDark}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="hidden dark:block border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
            <Image
                src={shapesLight}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="block dark:hidden border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
        </div>
        <div
            class="bg-fg-1 border border-stroke rounded-6 p-24 flex flex-col gap-16 h-435 overflow-clip max-[850px]:h-auto max-[520px]:p-16"
        >
            <h3 class="text-h3 leading-none max-[520px]:text-h4">
                Open source core
            </h3>
            <p class="text-body leading-relaxed text-text-subtitle">
                Built by the community, anyone can submit and fix issues, and
                contribute their ideas and features.
            </p>

            <Image
                src={tagsDark}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="hidden dark:block border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
            <Image
                src={tagsLight}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="block dark:hidden border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
        </div>
        <div
            class="bg-fg-1 border border-stroke rounded-6 p-24 flex flex-col gap-16 h-435 overflow-clip max-[850px]:h-auto max-[520px]:p-16"
        >
            <h3 class="text-h3 leading-none max-[520px]:text-h4">
                Free & easy to use
            </h3>
            <p class="text-body leading-relaxed text-text-subtitle">
                OpenMarch Desktop App will always stay free and easy to use,
                making drill writing accessible to all.
            </p>

            <Image
                src={fieldDark}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="hidden dark:block border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
            <Image
                src={fieldLight}
                alt="App Screenshot"
                width={1328}
                height={800}
                format="webp"
                quality={80}
                class="block dark:hidden border border-stroke aspect-1328/800 h-auto w-full rounded-6 object-center object-cover"
            />
        </div>
        <div
            class="bg-fg-1 border border-stroke rounded-6 p-24 flex h-435 flex-col gap-16 relative overflow-clip max-[850px]:h-auto max-[850px]:min-h-380 max-[520px]:min-h-320 max-[520px]:p-16"
        >
            <h3 class="text-h3 leading-none max-[520px]:text-h4">
                To your rehearsal
            </h3>
            <p class="text-body leading-relaxed text-text-subtitle">
                Export your drill to PDF as drill charts and coordinate sheets
                for performers. Upload your drill to OpenMarch: On The Move for
                a digital drill viewing experience.
            </p>

            <span
                class="inset-x-0 -bottom-72 flex items-center w-full justify-center max-[520px]:-bottom-48"
            >
                <span class="z-3">
                    <Image
                        src={viewVertDark}
                        alt="OTM Screenshot"
                        width={384}
                        height={786}
                        format="webp"
                        quality={80}
                        class="hidden dark:block aspect-384/786 h-393 w-auto object-center object-contain max-[950px]:h-340 max-[520px]:h-280"
                    />
                    <Image
                        src={viewVertLight}
                        alt="OTM Screenshot"
                        width={384}
                        height={786}
                        format="webp"
                        quality={80}
                        class="block dark:hidden aspect-384/786 h-393 w-auto object-center object-contain max-[950px]:h-340 max-[520px]:h-280"
                    />
                </span>

                <Image
                    src={drillchart}
                    alt="drill chart Screenshot"
                    width={576}
                    height={444}
                    format="webp"
                    quality={80}
                    class="aspect-288/222 h-222 -ml-48 z-2 w-auto object-center object-contain max-[950px]:h-190 max-[520px]:h-150 max-[520px]:-ml-32"
                />
            </span>
        </div>
    </section>
    <div
        class="p-32 flex justify-between items-center gap-16 border border-accent rounded-full max-[640px]:rounded-6 max-[640px]:p-16 max-[640px]:flex-col max-[640px]:items-stretch"
    >
        <h1 class="text-h1 max-[640px]:text-h2">Download for free</h1>
        <a
            href="/download"
            class={getButtonClassName({
                variant: "primary",
                className: "max-[640px]:w-full",
            })}
        >
            Download
        </a>
    </div>
</section>
