---
import { Button } from "@openmarch/ui";
---

<section
    class="w-full flex flex-col items-center justify-center gap-12"
    id="pricing"
>
    <h1 class="text-h1">Pricing</h1>
    <div
        class="w-sm border border-accent rounded-[36px] flex flex-col items-start justify-center gap-8 p-24"
    >
        <p class="text-sub font-mono">OPENMARCH: ON THE MOVE</p>
        <h2 class="text-h2">$5 per performer</h2>
        <ul class="list-disc pl-20">
            <li class="text-body">See your path and coordinates</li>
            <li class="text-body">Visualize the big picture</li>
            <li class="text-body">Speed up your show learning process</li>
            <li class="text-body">Built by the OpenMarch team</li>
        </ul>
        <a href="#"><Button variant="primary">Get Started</Button></a>
    </div>
</section>
