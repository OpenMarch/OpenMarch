{
    "name": "@openmarch/drill-interop",
    "license": "AGPL-3.0",
    "type": "module",
    "version": "1.0.0",
    "types": "dist/index.d.ts",
    "main": "dist/index.cjs",
    "description": "Reader for third-party drill interchange packages, used to import shows into OpenMarch",
    "homepage": "https://openmarch.com",
    "author": "OpenMarch LLC <contact@openmarch.com>",
    "publishConfig": {
        "access": "public"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/OpenMarch/OpenMarch.git"
    },
    "scripts": {
        "build": "tsup --format esm,cjs",
        "dev": "tsup --watch",
        "test": "vitest run --silent",
        "test:watch": "vitest"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist/**/*",
        "README.md",
        "LICENSE"
    ],
    "peerDependencies": {
        "typescript": "catalog:"
    },
    "dependencies": {
        "jszip": "^3.10.1"
    },
    "devDependencies": {
        "@openmarch/config": "workspace:*",
        "tsup": "^8.5.0",
        "typescript": "catalog:",
        "vitest": "^3.2.3"
    }
}
