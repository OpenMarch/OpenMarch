---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import placeholderImage from "@/content/blog/placeholder.jpg";
import { ProseClass } from "@/components/ProseClass";
import LexicalContent from "@/components/ui/LexicalContent";
import type { SerializedEditorState } from "@payloadcms/richtext-lexical/lexical";
import {
    generatePayloadPostSlug,
    getPayloadPosts,
    isPayloadCmsEnabled,
    parsePayloadPostToListItem,
    type PayloadPost,
} from "@/lib/payload";

export async function getStaticPaths() {
    const contentEntries = await getCollection("blog");
    const contentPaths = contentEntries.map((post) => ({
        params: { id: post.id },
        props: { source: "content" as const, post },
    }));

    if (!isPayloadCmsEnabled()) {
        return contentPaths;
    }

    const payloadPosts = await getPayloadPosts();
    const payloadPaths = payloadPosts.map((post: PayloadPost) => ({
        params: { id: generatePayloadPostSlug(post) },
        props: { source: "payload" as const, post },
    }));

    return [...contentPaths, ...payloadPaths];
}

type BlogPageProps =
    | { source: "content"; post: CollectionEntry<"blog"> }
    | { source: "payload"; post: PayloadPost };

const props = Astro.props as BlogPageProps;
const isContent = props.source === "content";
const contentPost = isContent ? props.post : null;
const payloadPost = !isContent ? props.post : null;

const payloadParsed = payloadPost
    ? parsePayloadPostToListItem(payloadPost, placeholderImage.src)
    : null;

const title = contentPost?.data.title ?? payloadParsed?.title ?? "";
const author = contentPost?.data.author ?? payloadParsed?.author ?? "";
const authorProfileImageUrl = payloadParsed?.authorProfileImageUrl ?? null;
const date = contentPost?.data.date ?? payloadParsed?.date ?? new Date();
const dateFormatted = date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
});

const { Content } = isContent
    ? await render(contentPost as CollectionEntry<"blog">)
    : { Content: null };
---

<Layout title={title}>
    <article
        class="relative flex w-full max-w-[50rem] flex-col items-center gap-16"
    >
        {
            isContent ? (
                <Image
                    src={
                        (contentPost as CollectionEntry<"blog">).data
                            .image as ImageMetadata
                    }
                    width={1280}
                    height={720}
                    alt=""
                    class="rounded-6 border-stroke aspect-video h-auto w-full border object-cover"
                />
            ) : payloadParsed ? (
                <Image
                    src={payloadParsed.imageUrl}
                    width={payloadParsed.imageWidth ?? 1280}
                    height={payloadParsed.imageHeight ?? 720}
                    alt={payloadParsed.imageAlt}
                    class="rounded-6 border-stroke aspect-video h-auto w-full border object-cover"
                />
            ) : null
        }
        <div
            class="absolute top-[10vh] left-1/2 -z-50 aspect-video h-auto w-full -translate-x-1/2"
            style="background: radial-gradient(ellipse, oklch(from var(--color-accent) l c h / 0.3) 0%, transparent 70%);"
        >
        </div>
        <h1 class="text-h3 text-center">{title}</h1>
        <div class="flex items-center gap-16">
            {
                authorProfileImageUrl ? (
                    <Image
                        src={authorProfileImageUrl}
                        alt=""
                        width={payloadParsed?.authorProfileImageWidth ?? 112}
                        height={payloadParsed?.authorProfileImageHeight ?? 112}
                        class="size-32 shrink-0 rounded-full object-cover"
                    />
                ) : null
            }
            <p class="text-body">{author}</p>
            <p class="text-body">{dateFormatted}</p>
        </div>
        {
            isContent && Content ? (
                <div class={ProseClass}>
                    <Content />
                </div>
            ) : props.source === "payload" ? (
                <LexicalContent
                    data={
                        (payloadPost as PayloadPost).content as
                            | SerializedEditorState
                            | null
                            | undefined
                    }
                />
            ) : null
        }
    </article>
</Layout>
