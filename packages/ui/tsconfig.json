{
    "extends": "astro/tsconfigs/strict",
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "jsx": "react-jsx",
        "jsxImportSource": "react",
        "paths": {
            "@/*": ["./src/*"]
        },
        // Ignore 6.0 deprecations for now. Needs dependencies to be updated.
        "ignoreDeprecations": "6.0"
    },
    "include": [".astro/types.d.ts", "**/*"],
    "exclude": ["dist"]
}
