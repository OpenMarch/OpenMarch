---
import { ThemeSwitcher } from "@openmarch/ui/astro";
import { LogoOpenMarchText, LogoOpenMarchMarcher } from "./Logos";
import { Button } from "@openmarch/ui";

interface Props {
    hideDownloadCta?: boolean;
}

const { hideDownloadCta } = Astro.props;

const isExternalLink = (href: string) => href.startsWith("http");

const footerItems = [
    {
        header: "Desktop",
        items: [
            { name: "Download", href: "/download" },
            { name: "Releases", href: "/download#releases" },
            { name: "Guides", href: "/guides" },
            { name: "Support", href: "/guides" },
            { name: "GitHub", href: "https://github.com/OpenMarch" },
        ],
    },
    {
        header: "Mobile",
        items: [
            { name: "On The Move", href: "/mobile" },
            { name: "Pricing", href: "/mobile#pricing" },
            { name: "Guides", href: "/guides" },
            { name: "Support", href: "/guides" },
        ],
    },
    {
        header: "Support & follow us",
        items: [
            { name: "Merch", href: "https://store.openmarch.com" },
            { name: "Patreon", href: "https://www.patreon.com/openmarch" },
            { name: "Discord", href: "https://discord.gg/eTsQ98uZzq" },
            {
                name: "Instagram",
                href: "https://www.instagram.com/openmarchapp/",
            },
            {
                name: "Facebook Group",
                href: "https://facebook-group.openmarch.com",
            },
            { name: "YouTube", href: "https://www.youtube.com/@OpenMarchApp" },
        ],
    },
    {
        header: "Find us",
        items: [
            { name: "Contact", href: "/contact" },
            { name: "Events", href: "/events" },
        ],
    },
    {
        header: "Organization",
        items: [
            { name: "About", href: "/about" },
            { name: "Blog", href: "/blog" },
            { name: "Terms of Service", href: "/legal/terms" },
            { name: "Privacy Policy", href: "/legal/privacy" },
            { name: "Refund Policy", href: "/legal/refunds" },
        ],
    },
];
---

<footer class="flex flex-col gap-8 z-50 w-full">
    {
        !hideDownloadCta && (
            <div
                class="flex gap-24
            items-center justify-center rounded-6 px-16 py-32 download-cta-gradient"
            >
                <LogoOpenMarchMarcher
                    width="24"
                    height="64"
                    className="text-accent"
                />
                <h2 class="text-h2 text-center max-[768px]:text-h3">
                    Download the modern drill writing app
                </h2>
                <a
                    href="/download"
                    class="text-body duration-150 ease-out hover:text-accent w-fit"
                >
                    <Button variant="primary">Download</Button>
                </a>
            </div>
        )
    }
    <footer class="grid grid-cols-6 gap-0 px-8 py-12 divide-x divide-stroke">
        <div
            class="flex flex-col justify-between px-16 py-12 max-[1024px]:col-span-2 max-[768px]:col-span-1"
        >
            <div class="flex flex-col gap-16">
                <a href="/">
                    <LogoOpenMarchText height="36" width="66" />
                </a>
                <a
                    class="text-body text-text-subtitle leading-[150%] hover:text-accent duration-150 ease-out"
                    href="mailto:contact@openmarch.com"
                >
                    contact@openmarch.com
                </a>
                <ThemeSwitcher />
            </div>
        </div>
        {
            footerItems.map(({ header, items }) => (
                <div class="flex flex-col gap-16 px-16 max-[768px]:pt-32">
                    <h4 class="text-h4">{header}</h4>
                    {items.map((item) => (
                        <a
                            href={item.href}
                            target={
                                isExternalLink(item.href) ? "_blank" : undefined
                            }
                            rel={
                                isExternalLink(item.href)
                                    ? "noopener noreferrer"
                                    : undefined
                            }
                            class="text-body text-text-subtitle duration-150 ease-out hover:text-accent w-fit"
                        >
                            {item.name}
                        </a>
                    ))}
                </div>
            ))
        }
    </footer>
</footer>
